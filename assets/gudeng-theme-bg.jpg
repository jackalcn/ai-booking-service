                }
                
                .error-404-icon {
                    font-size: 80px;
                    color: #1f4965;
                    margin-bottom: 20px;
                    animation: bounce 2s infinite;
                }
                
                .error-404-title {
                    font-size: 32px;
                    font-weight: 600;
                    color: #333;
                    margin: 20px 0 15px;
                    animation: fadeIn 1s ease-out 0.3s both;
                }
                
                .error-404-message {
                    font-size: 18px;
                    color: #666;
                    margin-bottom: 40px;
                    max-width: 600px;
                    line-height: 1.6;
                    animation: fadeIn 1s ease-out 0.5s both;
                }
                
                .error-404-buttons {
                    display: flex;
                    gap: 15px;
                    flex-wrap: wrap;
                    justify-content: center;
                    animation: fadeInUp 1s ease-out 0.7s both;
                }
                
                .error-404-btn {
                    display: inline-block;
                    padding: 15px 40px;
                    font-size: 16px;
                    font-weight: 600;
                    text-decoration: none;
                    border-radius: 50px;
                    transition: all 0.3s ease;
                    box-shadow: 0 4px 15px rgba(0,0,0,0.1);
                }
                
                .error-404-btn-primary {
                    background: linear-gradient(135deg, #1f4965 0%, #2d6a8f 100%);
                    color: white;
                }
                
                .error-404-btn-primary:hover {
                    background: linear-gradient(135deg, #2d6a8f 0%, #1f4965 100%);
                    transform: translateY(-2px);
                    box-shadow: 0 6px 20px rgba(31,73,101,0.3);
                    color: white;
                    text-decoration: none;
                }
                
                .error-404-btn-secondary {
                    background: white;
                    color: #1f4965;
                    border: 2px solid #1f4965;
                }
                
                .error-404-btn-secondary:hover {
                    background: #1f4965;
                    color: white;
                    transform: translateY(-2px);
                    box-shadow: 0 6px 20px rgba(31,73,101,0.2);
                    text-decoration: none;
                }
                
                @keyframes fadeInDown {
                    from {
                        opacity: 0;
                        transform: translateY(-30px);
                    }
                    to {
                        opacity: 1;
                        transform: translateY(0);
                    }
                }
                
                @keyframes fadeInUp {
                    from {
                        opacity: 0;
                        transform: translateY(30px);
                    }
                    to {
                        opacity: 1;
                        transform: translateY(0);
                    }
                }
                
                @keyframes fadeIn {
                    from {
                        opacity: 0;
                    }
                    to {
                        opacity: 1;
                    }
                }
                
                @keyframes bounce {
                    0%, 100% {
                        transform: translateY(0);
                    }
                    50% {
                        transform: translateY(-10px);
                    }
                }
                
                @media (max-width: 768px) {
                    .error-404-number {
                        font-size: 100px;
                    }
                    .error-404-icon {
                        font-size: 60px;
                    }
                    .error-404-title {
                        font-size: 24px;
                    }
                    .error-404-message {
                        font-size: 16px;
                    }
                    .error-404-buttons {
                        flex-direction: column;
                    }
                    .error-404-btn {
                        width: 100%;
                        max-width: 300px;
                    }
                }
