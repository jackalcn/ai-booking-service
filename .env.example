# 本機執行：將此檔案另存為 .env 並填入 API Key
# Streamlit Cloud：請將相同鍵值貼到 App 的 Secrets（非上傳 .env）
# AI_PROVIDER 可設為：auto / openai / gemini
# 此專案為家登精密內部使用的訂房與客服系統
AI_PROVIDER=auto

OPENAI_API_KEY=請在這裡放入你的 API Key
OPENAI_MODEL=gpt-4o-mini

# Google Gemini 金鑰可於 Google AI Studio 取得
GOOGLE_API_KEY=請在這裡放入你的 Google Gemini API Key
# 也可改填 GEMINI_API_KEY（程式會自動相容讀取）
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# -----------------------------
# SSO 設定（內網反向代理 Claim）
# -----------------------------
# 啟用後，系統會嘗試從 Query/Header/Secrets 讀取員工資料
ENABLE_SSO=false

# 可作為本機測試預設值（無 Claim 時使用）
SSO_EMPLOYEE_ID=
SSO_USER_NAME=
SSO_USER_DEPT=
SSO_USER_EMAIL=
SSO_USER_EXT=
SSO_USER_ROLES=

# -----------------------------
# 審核權限設定
# -----------------------------
# 多人請用逗號分隔，例如 GD1001,GD1002
ADMIN_EMPLOYEE_IDS=
ADMIN_NAMES=吳佩綺

# 非 SSO 管理員時可用臨時解鎖碼
ADMIN_REVIEW_PASSCODE=

# -----------------------------
# 通知設定（Email / Teams）
# -----------------------------
NOTIFY_EMAIL_ENABLED=false
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_USE_TLS=true

# 新訂房通知收件者，多人請用逗號分隔
BOOKING_NOTIFY_TO_EMAIL=

NOTIFY_TEAMS_ENABLED=false
TEAMS_WEBHOOK_URL=
